# Benchmark run config (written per-run by benchmark runner, never committed)
.claude/bench-config.json

node_modules/
.next/
dist/
build/
.env
.env.*
!.env.example

# Build artifacts (generated by strux build, not committed)
.openstrux/

# Language docs (injected by benchmark runner from openstrux-spec, not source)
openstrux-lang/

# LLM-generated source mirror (written by benchmark runner — not source)
output/

# Strux source files written during benchmark runs (not part of baseline)
# These are generated by the LLM and cleaned by scripts/reset.sh
strux.context
pipelines/**/*.strux
pipelines/strux.context
openspec/specs/*.strux
