// prisma/schema.prisma
// Domain model for the grant workflow system.
// Entity names: PascalCase (Prisma); DB tables: snake_case via @@map.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String @id @default(cuid())
  displayName  String
  email        String @unique
  role         String
  passwordHash String

  @@map("user")
}

model Call {
  id                       String    @id @default(cuid())
  title                    String
  description              String?
  openDate                 DateTime?
  closeDate                DateTime?
  status                   String    @default("open")
  enabledEligibilityChecks Json      @default("[]")
  maxBudgetKEur            Float     @default(500)
  reviewerPolicyVersion    String?

  @@map("call")
}

model Submission {
  id             String   @id @default(cuid())
  callId         String
  applicantAlias String
  status         String   @default("submitted")
  submittedAt    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  proposalVersions  ProposalVersion[]
  applicantIdentity ApplicantIdentity?
  eligibilityRecord EligibilityRecord?

  @@map("submission")
}

model ProposalVersion {
  id                  String   @id @default(cuid())
  submissionId        String
  versionNumber       Int      @default(1)
  isEffective         Boolean  @default(true)
  title               String
  abstract            String
  requestedBudgetKEur Float
  budgetUsage         String
  tasksBreakdown      String
  attachmentsMeta     Json?
  createdAt           DateTime @default(now())

  submission    Submission    @relation(fields: [submissionId], references: [id])
  blindedPacket BlindedPacket?

  @@map("proposal_version")
}

model ApplicantIdentity {
  id           String @id @default(cuid())
  submissionId String @unique
  legalName    String
  email        String
  country      String
  organisation String

  submission Submission @relation(fields: [submissionId], references: [id])

  @@map("applicant_identity")
}

model BlindedPacket {
  id                String @id @default(cuid())
  proposalVersionId String @unique
  content           Json

  proposalVersion ProposalVersion @relation(fields: [proposalVersionId], references: [id])

  @@map("blinded_packet")
}

model EligibilityRecord {
  id             String   @id @default(cuid())
  submissionId   String   @unique
  status         String
  inputs         Json
  activeRules    Json     @default("[]")
  failureReasons Json     @default("[]")
  evaluatedAt    DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id])

  @@map("eligibility_record")
}

model AuditEvent {
  id         String   @id @default(cuid())
  eventType  String
  actorId    String
  targetType String
  targetId   String
  payload    Json     @default("{}")
  timestamp  DateTime @default(now())

  @@map("audit_event")
}
