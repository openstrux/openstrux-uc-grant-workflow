{
  "name": "openstrux-uc-grant-workflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":          "pnpm --filter @grant-workflow/web dev",
    "build":        "pnpm --filter @grant-workflow/web build",
    "type-check":   "pnpm -r type-check",
    "lint":         "eslint . --ext .ts,.tsx",
    "lint:fix":     "eslint . --ext .ts,.tsx --fix",
    "format":       "prettier --write \"**/*.{ts,tsx,json,md,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yaml}\"",
    "test":         "vitest run",
    "test:unit":    "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e":     "vitest run tests/e2e",
    "validate":     "pnpm type-check && pnpm lint && pnpm format:check && pnpm test:unit",
    "reset":        "bash scripts/reset.sh"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
