{
  "name": "openstrux-uc-grant-workflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":                  "next dev",
    "build":                "next build",
    "start":                "next start",
    "type-check":           "tsc --noEmit",
    "lint":                 "eslint . --ext .ts,.tsx",
    "lint:fix":             "eslint . --ext .ts,.tsx --fix",
    "format":               "prettier --write \"**/*.{ts,tsx,json,md,yaml}\"",
    "format:check":         "prettier --check \"**/*.{ts,tsx,json,md,yaml}\"",
    "test":                 "vitest run",
    "test:unit":            "vitest run tests/unit",
    "test:integration":     "vitest run tests/integration",
    "test:integration:mock":"vitest run tests/integration-mock",
    "test:e2e":             "vitest run tests/e2e",
    "validate":             "pnpm type-check && pnpm lint && pnpm format:check && pnpm test:unit",
    "db:seed":              "prisma db seed",
    "reset":                "bash scripts/reset.sh"
  },
  "dependencies": {
    "@headlessui/react":        "^2.1.0",
    "@prisma/client":           "^6.0.0",
    "lucide-react":             "^0.400.0",
    "next":                     "^15.0.0",
    "next-auth":                "^4.24.0",
    "react":                    "^18.3.0",
    "react-dom":                "^18.3.0",
    "zod":                      "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt":                      "^5.0.0",
    "@types/node":                        "^20.0.0",
    "@types/react":                       "^18.3.0",
    "@types/react-dom":                   "^18.3.0",
    "@typescript-eslint/eslint-plugin":   "^7.0.0",
    "@typescript-eslint/parser":          "^7.0.0",
    "bcrypt":                             "^5.1.0",
    "eslint":                             "^8.57.0",
    "eslint-config-prettier":             "^9.1.0",
    "eslint-plugin-react":                "^7.34.0",
    "eslint-plugin-react-hooks":          "^4.6.0",
    "prettier":                           "^3.2.0",
    "prisma":                             "6.19.2",
    "typescript":                         "^5.5.0",
    "vitest":                             "^1.6.0",
    "vitest-mock-extended":               "^2.0.0"
  },
  "prisma": {
    "seed": "node --experimental-strip-types prisma/seeds/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  }
}
